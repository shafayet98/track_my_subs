# Copy to .env and fill in. Never commit .env.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/track_my_subs

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=60

# --- Encryption for stored OAuth refresh tokens ---
TOKEN_ENCRYPTION_KEY=change-me-32-byte-base64-fernet-key

# --- Google OAuth (Gmail, read-only) ---
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/accounts/gmail/callback

# --- App ---
FRONTEND_ORIGIN=http://localhost:5173
