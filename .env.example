# Copy to .env and fill in. Never commit .env.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/track_my_subs

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=60

# --- Encryption for stored OAuth refresh tokens ---
TOKEN_ENCRYPTION_KEY=change-me-32-byte-base64-fernet-key

# --- Google OAuth (Gmail, read-only) ---
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/accounts/gmail/callback

# --- App ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Notifications (alert emails via AWS SES) ---
# Leave SES_SENDER empty in dev to disable sending (the worker logs and skips).
# In prod it must be a verified SES identity; creds come from the task role.
AWS_REGION=ap-southeast-2
SES_SENDER=
APP_BASE_URL=http://localhost:5173
